// REQUIRES: TARGET-SM_90A
// RUN: choreo -es -t cute -arch=sm_90a %s -o - | FileCheck %s --check-prefix=CODEGEN
// RUN: choreo -gs -t cute -arch=sm_90a %s -o %s.cute.result && CUDA_VISIBLE_DEVICES=1 CHOREO_DISABLE_TIMING=1 bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

#define M 64
#define N 64
#define K 64

__co__ auto matmul(f16 [M, K] lhs, f16 [K, N] rhs) {
  f16 [M, N] output{0.0f};

  int WARP_M = 64, WARP_N = 64, TILE_K = 64, WARP_K = 16;

  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      lhs_s = dma.copy.swiz<128> lhs.chunkat(block_m, iv_k) => shared;
      rhs_s = dma.copy.swiz<128> rhs.chunkat(iv_k, block_n) => shared;

      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.load.swiz<128> lhs_s.chunkat(_, iv_warp);
          mb = mma.load.swiz<128> rhs_s.chunkat(iv_warp, _);
          mma.row.col mc, ma, mb;
        }
      }
    }
    mma.store mc, output.chunkat(block_m, block_n);
  }

  return output;
}

int main() {
  auto lhs = choreo::make_spandata<choreo::f16>(M, K);
  auto rhs = choreo::make_spandata<choreo::f16>(K, N);
  lhs.fill_random(0.0f, 2.0f);
  rhs.fill_random(0.0f, 2.0f);

  auto res = matmul(lhs.view(), rhs.view());

  float base_tol = 0.05f;
  float rel_tol = 0.02f;
  choreo::verify_matmul_row_col_subset(lhs, rhs, res, base_tol, rel_tol, 8, 8);

  std::cout << "Test Passed\n" << std::endl;
}

