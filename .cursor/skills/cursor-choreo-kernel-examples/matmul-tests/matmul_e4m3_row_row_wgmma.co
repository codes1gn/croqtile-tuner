// REQUIRES: TARGET-SM_90A
// RUN: choreo -gs -t cute -arch=sm_90a %s -o %s.cute.result && CUDA_VISIBLE_DEVICES=1 CHOREO_DISABLE_TIMING=1 bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

#define WARP_M 64
#define WARP_N 128
#define TILE_K 128
#define WARP_K 32

#define M 128
#define N 128
#define K 128

__co__ void matmul(global f8_e4m3 [M, K] lhs, global f8_e4m3 [N, K] rhs,
                   global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    shared f8_e4m3 [WARP_M, TILE_K] lhs_s;
    shared f8_e4m3 [WARP_N, TILE_K] rhs_s;
    mc = mma.fill.f16 0.0f;

    foreach {iv_k} in [cdiv(K, TILE_K)] {
      tma.copy.swiz<128> lhs.subspan(WARP_M, TILE_K).at(block_m, iv_k) => lhs_s;
      tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_s;

      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.load.swiz<128> lhs_s.chunkat(_, iv_warp);
          mb = mma.load.swiz<128> rhs_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;
        }
      }
    }

    shared f16 [WARP_M, WARP_N] output_s;
    mma.store mc, output_s;
    tma.copy output_s => output.subspan(WARP_M, WARP_N).at(block_m, block_n);
  }
}

int main() {
  auto lhs_h = choreo::make_spandata<choreo::f8_e4m3>(M, K);
  auto rhs_h = choreo::make_spandata<choreo::f8_e4m3>(N, K);
  auto res_h = choreo::make_spandata<choreo::f16>(M, N);
  lhs_h.fill_random(0.0f, 2.0f);
  rhs_h.fill_random(0.0f, 2.0f);
  res_h.fill(0.0f);

  __nv_fp8_e4m3* a_d = nullptr;
  __nv_fp8_e4m3* b_d = nullptr;
  half* c_d = nullptr;
  choreo::abend_true(cudaMalloc(&a_d, M * K * sizeof(__nv_fp8_e4m3)));
  choreo::abend_true(cudaMalloc(&b_d, N * K * sizeof(__nv_fp8_e4m3)));
  choreo::abend_true(cudaMalloc(&c_d, M * N * sizeof(half)));

  choreo::abend_true(cudaMemcpy(a_d, lhs_h.data(), M * K * sizeof(__nv_fp8_e4m3),
                                cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(b_d, rhs_h.data(), N * K * sizeof(__nv_fp8_e4m3),
                                cudaMemcpyHostToDevice));
  choreo::abend_true(
      cudaMemcpy(c_d, res_h.data(), M * N * sizeof(half), cudaMemcpyHostToDevice));

  auto lhs_d = choreo::make_spanview<choreo::f8_e4m3, 2>(a_d, {M, K});
  auto rhs_d = choreo::make_spanview<choreo::f8_e4m3, 2>(b_d, {N, K});
  auto res_d = choreo::make_spanview<choreo::f16, 2>(c_d, {M, N});

  matmul(lhs_d, rhs_d, res_d);
  choreo::abend_true(cudaDeviceSynchronize());
  choreo::abend_true(
      cudaMemcpy(res_h.data(), c_d, M * N * sizeof(half), cudaMemcpyDeviceToHost));

  float base_tol = 0.3f;
  float rel_tol = 0.05f;
  choreo::verify_matmul_row_row_subset(lhs_h, rhs_h, res_h, base_tol, rel_tol,
                                       8, 8);

  std::cout << "Test Passed\n" << std::endl;
}

// CHECK: Test Passed
