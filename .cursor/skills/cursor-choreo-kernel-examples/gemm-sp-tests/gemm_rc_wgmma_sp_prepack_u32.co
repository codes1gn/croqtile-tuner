// REQUIRES: TARGET-SM_90A
// RUN: choreo -gs -t cute -arch=sm_90a --use-prepack %s -o %s.cute.result && CHOREO_DISABLE_TIMING=1 bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

// Tests: WGMMA sparse with prepack u32 metadata (--use-prepack flag).
// The prepack kernel requires K >= 4096 (tile column = iv_k * 128, needs K/32 >= 128).
// Covers f16 with SparsePolicyWGMMA::prepack() u32 metadata encoding.

template <typename T>
using SparsePolicyWGMMA = choreo::utils::SparsePolicyWGMMA<T>;

template <typename T>
void init_random_b(choreo::spanned_data<T, 2>& rhs, std::mt19937& gen) {
  std::uniform_real_distribution<float> dist(-1.0f, 1.0f);
  for (size_t j = 0; j < rhs.shape()[0]; ++j)
    for (size_t k = 0; k < rhs.shape()[1]; ++k) {
      float value = dist(gen);
      if (std::fabs(value) < 0.1f) value = (value < 0.0f ? -0.25f : 0.25f);
      rhs[j][k] = choreo::utils::from_f32<T>(value);
    }
}

// Kernel: f16 sparse WGMMA with prepack u32 metadata, K=4096 (required by tile layout)
#define TEST_M 128
#define TEST_K 4096
#define TEST_N 128
#define WARP_M 64
#define WARP_N 128
#define TILE_K 64
#define WARP_K 32
#define LHS_SWIZ 64
#define RHS_SWIZ 128

__co__ auto matmul_sp_f16_prepack(
    f16 [TEST_M, TEST_K / 2] lhs_packed,
    u32 [TEST_M, TEST_K / 32] lhs_meta,
    f16 [TEST_N, TEST_K] rhs) {
  f32 [TEST_M, TEST_N] output{0.0f};
  parallel {block_m, block_n} by [cdiv(TEST_M, WARP_M), cdiv(TEST_N, WARP_N)] : block {
    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(TEST_K, TILE_K)] {
      lhs_load_s = tma.copy.swiz<LHS_SWIZ> lhs_packed.chunkat(block_m, iv_k) => shared;
      rhs_load_s = tma.copy.swiz<RHS_SWIZ> rhs.chunkat(block_n, iv_k) => shared;
      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.load.swiz<LHS_SWIZ> lhs_load_s.chunkat(_, iv_warp);
          mb = mma.load.swiz<RHS_SWIZ> rhs_load_s.chunkat(_, iv_warp);
          me = mma.load lhs_meta.chunkat(block_m, iv_k#iv_warp);
          mma.row.row.sp mc, ma, mb, me;
        }
      }
    }
    shared f32 [WARP_M, WARP_N] os;
    mma.store mc, os;
    tma.copy os => output.chunkat(block_m, block_n);
  }
  return output;
}

int main() {
  int errors = 0;

  // f16 prepack test
  {
    std::mt19937 gen(42);
    auto ld = choreo::make_spandata<choreo::f16>(TEST_M, TEST_K);
    auto lp = choreo::make_spandata<choreo::f16>(TEST_M, TEST_K / 2);
    auto lm_u8 = choreo::make_spandata<choreo::u8>(TEST_M, TEST_K / 8);
    auto lm_u32 = choreo::make_spandata<choreo::u32>(TEST_M, TEST_K / 32);
    auto rh = choreo::make_spandata<choreo::f16>(TEST_N, TEST_K);
    SparsePolicyWGMMA<choreo::f16>::init_structured_sparse_A(ld, gen);
    init_random_b<choreo::f16>(rh, gen);
    SparsePolicyWGMMA<choreo::f16>::encode(ld, lp, lm_u8);
    SparsePolicyWGMMA<choreo::f16>::prepack(lm_u8, lm_u32);
    auto res = matmul_sp_f16_prepack(lp.view(), lm_u32.view(), rh.view());
    // Verify all elements (small matrix)
    for (size_t i = 0; i < TEST_M; ++i)
      for (size_t j = 0; j < TEST_N; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < TEST_K; ++k)
          ref += choreo::to_f32(ld.data()[i * TEST_K + k]) * choreo::to_f32(rh.data()[j * TEST_K + k]);
        float got = res.data()[i * TEST_N + j];
        float diff = std::abs(got - ref);
        if (diff > 0.5f) ++errors;
      }
    std::cout << "f16_prepack: " << errors << " errors\n";
  }

  choreo::choreo_assert(errors == 0, "Prepack sparse WGMMA tests failed");
  std::cout << "Test Passed\n";
}

// CHECK: f16_prepack: 0 errors
// CHECK: Test Passed
