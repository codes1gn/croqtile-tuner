#undef M
#undef N
#undef K

static bool check_timing_disabled(int argc, char** argv) {
  for (int i = 1; i < argc; ++i) {
    const char* s = argv[i];
    const char* t = "--disable-timing";
    int j = 0;
    while (t[j] != '\0' && s[j] == t[j]) ++j;
    if (t[j] == '\0' && s[j] == '\0') return true;
  }
  const char* env = std::getenv("CHOREO_DISABLE_TIMING");
  return env && env[0] == '1' && env[1] == '\0';
}

int main(int argc, char** argv) {
  bool disable_timing = check_timing_disabled(argc, argv);
  (void)disable_timing;

  // --- f16 WGMMA+TMA (256x256x256) ---
  {
    const int M = 256, N = 256, K = 256;
    auto lhs = choreo::make_spandata<choreo::f16>(M, K);
    auto rhs = choreo::make_spandata<choreo::f16>(N, K);
    lhs.fill_random(0, 2);
    rhs.fill_random(0, 2);
    auto res = matmul_f16_wgmma_tma(lhs.view(), rhs.view());
    float tolerance = 0.01f;
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        __half ref = 0.0f;
        for (size_t k = 0; k < (size_t)K; ++k)
          ref += __half2float(lhs[i][k]) * __half2float(rhs[j][k]);
        auto delta = std::abs((__half2float(ref) - __half2float(res[i][j])) / __half2float(ref));
        if (delta >= tolerance)
          std::cout << "[" << i << ", " << j << "] " << __half2float(ref) << " <-> " << __half2float(res[i][j]) << ", delta: " << delta * 100 << "%\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }
    std::cout << "Test f16_wgmma_tma Passed\n";
  }

  // --- f8_e4m3 WGMMA+TMA N=64 ---
  {
    const int M = 64, N = 64, K = 32;
    auto lhs = choreo::make_spandata<choreo::f8_e4m3>(M, K);
    auto rhs = choreo::make_spandata<choreo::f8_e4m3>(N, K);
    lhs.fill_random(-2.0f, 2.0f);
    rhs.fill_random(-2.0f, 2.0f);
    auto res = matmul_fp8_e4m3_n64(lhs.view(), rhs.view());
    choreo::verify_matmul_row_row_subset(lhs, rhs, res, 0.3f, 0.05f, 8, 8);
    std::cout << "Test fp8_e4m3_n64 Passed\n";
  }

  // --- f8_e4m3 WGMMA+TMA N=192 ---
  {
    const int M = 64, N = 192, K = 32;
    auto lhs = choreo::make_spandata<choreo::f8_e4m3>(M, K);
    auto rhs = choreo::make_spandata<choreo::f8_e4m3>(N, K);
    lhs.fill_random(-2.0f, 2.0f);
    rhs.fill_random(-2.0f, 2.0f);
    auto res = matmul_fp8_e4m3_n192(lhs.view(), rhs.view());
    choreo::verify_matmul_row_row_subset(lhs, rhs, res, 0.3f, 0.05f, 8, 8);
    std::cout << "Test fp8_e4m3_n192 Passed\n";
  }

  // --- f8_e5m2 WGMMA+TMA N=128 ---
  {
    const int M = 64, N = 128, K = 32;
    auto lhs = choreo::make_spandata<choreo::f8_e5m2>(M, K);
    auto rhs = choreo::make_spandata<choreo::f8_e5m2>(N, K);
    lhs.fill_random(-2.0f, 2.0f);
    rhs.fill_random(-2.0f, 2.0f);
    auto res = matmul_fp8_e5m2_n128(lhs.view(), rhs.view());
    choreo::verify_matmul_row_row_subset(lhs, rhs, res, 0.35f, 0.06f, 8, 8);
    std::cout << "Test fp8_e5m2_n128 Passed\n";
  }

  // --- f8_e4m3 WGMMA+TMA N=128 ---
  {
    const int M = 64, N = 128, K = 32;
    auto lhs = choreo::make_spandata<choreo::f8_e4m3>(M, K);
    auto rhs = choreo::make_spandata<choreo::f8_e4m3>(N, K);
    lhs.fill_random(-2.0f, 2.0f);
    rhs.fill_random(-2.0f, 2.0f);
    auto res = matmul_fp8_e4m3_n128(lhs.view(), rhs.view());
    choreo::verify_matmul_row_row_subset(lhs, rhs, res, 0.3f, 0.05f, 8, 8);
    std::cout << "Test fp8_e4m3_n128 Passed\n";
  }

  std::cout << "All Tests Passed\n" << std::endl;
}

// CHECK: Test f16_wgmma_tma Passed
// CHECK: Test fp8_e4m3_n64 Passed
// CHECK: Test fp8_e4m3_n192 Passed
// CHECK: Test fp8_e5m2_n128 Passed
// CHECK: Test fp8_e4m3_n128 Passed
// CHECK: All Tests Passed
