# CroqTuner Monitor Configuration
# Copy this to .env and adjust as needed

# Path overrides (defaults are relative to croqtile-tuner project root)
# CROQTUNER_TUNING_DIR=/home/albert/workspace/croqtile-tuner/tuning
# CROQTUNER_SKILLS_DIR=/home/albert/workspace/croqtile-tuner/.claude/skills
# CROQTUNER_PROJECT_DIR=/home/albert/workspace/croqtile-tuner

# Server settings
CROQTUNER_HOST=0.0.0.0
CROQTUNER_PORT=8642

# Heartbeat interval in seconds
CROQTUNER_HEARTBEAT_SEC=30

# GPU selection
CROQTUNER_CUDA_VISIBLE_DEVICES=0

# Mock mode (set to true to run without opencode)
# CROQTUNER_MOCK_MODE=false

# OpenCode settings
# CROQTUNER_OPENCODE_MODEL=opencode/big-pickle
# CROQTUNER_OPENCODE_VARIANT=high

# Choreo compiler paths
CROQTUNER_CHOREO_HOME=/home/albert/workspace/croqtile
CROQTUNER_CUTE_HOME=/home/albert/workspace/croqtile/extern/cutlass
