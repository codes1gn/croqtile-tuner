[Unit]
Description=CroqTuner monitor backend (FastAPI)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/albert/workspace/croqtile-tuner/monitor/backend
EnvironmentFile=-/home/albert/workspace/croqtile-tuner/monitor/.env
Environment=CROQTUNER_PROJECT_DIR=/home/albert/workspace/croqtile-tuner
Environment=CROQTUNER_TUNING_DIR=/home/albert/workspace/croqtile-tuner/tuning
Environment=CROQTUNER_SKILLS_DIR=/home/albert/workspace/croqtile-tuner/.claude/skills
ExecStart=/home/albert/workspace/croqtile-tuner/monitor/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8642
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
