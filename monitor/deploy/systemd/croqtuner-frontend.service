[Unit]
Description=CroqTuner monitor frontend (Vite)
After=network-online.target croqtuner-backend.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/albert/workspace/croqtile-tuner/monitor/frontend
ExecStart=/usr/bin/npx -y node@20 node_modules/vite/bin/vite.js --host 0.0.0.0 --port 5173
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
