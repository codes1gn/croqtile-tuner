#define M 4096
#define N 2048
#define K 2048
// #define M 512 
// #define N 512 
// #define K 512 

__co__ auto matmul(f16 [M, K] lhs, f16 [N, K] rhs) {
  f16 [M, N] output{0.0f};

  int WARP_M = 64, WARP_N = 64, TILE_K = 64, WARP_K = 16;

  // each block handles 64x64 block with WGMMA
  // WGMMA requires 128 threads (4 warps x 32 threads/warp)
  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      // load 64x64 to smem
      // Test new syntax: dma.copy.swiz<128>
      lhs_load_s = tma.copy.swiz<128> lhs.chunkat(block_m, iv_k) => shared;
      rhs_load_s = tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => shared;
      // WGMMA requires 128 threads: 4 warps x 32 threads/warp
      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.load.swiz<128> lhs_load_s.chunkat(_, iv_warp);
          mb = mma.load.swiz<128> rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;   // row * col : c += a * b;
        }
      }
    }
    mma.store mc, output.chunkat(block_m, block_n);
  }

  return output;
}

__co__ void matmul_global(global f16 [M, K] lhs, global f16 [N, K] rhs, global f16 [M, N] output) {
  int WARP_M = 64, WARP_N = 64, TILE_K = 64, WARP_K = 16;

  // each block handles 64x64 block with WGMMA
  // WGMMA requires 128 threads (4 warps x 32 threads/warp)
  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    mc = mma.fill.f32 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      // load 64x64 to smem
      // Test new syntax: dma.copy.swiz<128>
      lhs_load_s = tma.copy.swiz<128> lhs.chunkat(block_m, iv_k) => shared;
      rhs_load_s = tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => shared;
      // WGMMA requires 128 threads: 4 warps x 32 threads/warp
      foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.load.swiz<128> lhs_load_s.chunkat(_, iv_warp);
          mb = mma.load.swiz<128> rhs_load_s.chunkat(_, iv_warp);
          mma.row.row mc, ma, mb;   // row * col : c += a * b;
        }
      }
    }
    mma.store mc, output.chunkat(block_m, block_n);
  }
}

int main(int argc, char** argv) {
  bool enable_timing = true;
  auto is_disable_timing_arg = [](const char* s) {
    const char* t = "--disable-timing";
    int i = 0;
    while (t[i] != '\0' && s[i] == t[i]) ++i;
    return t[i] == '\0' && s[i] == '\0';
  };
  for (int i = 1; i < argc; ++i) {
    if (is_disable_timing_arg(argv[i])) {
      enable_timing = false;
      break;
    }
  }

  const char* timing_env = std::getenv("CHOREO_DISABLE_TIMING");
  if (timing_env && timing_env[0] == '1' && timing_env[1] == '\0') {
    enable_timing = false;
  }

  auto lhs = choreo::make_spandata<choreo::f16>(M, K);
  auto rhs = choreo::make_spandata<choreo::f16>(N, K);
  lhs.fill_random(0, 2);
  rhs.fill_random(0, 2);

  // allocate device buffers and copy host -> device so timing measures only kernel
  half *lhs_d = nullptr, *rhs_d = nullptr, *res_d = nullptr;
  choreo::abend_true(cudaMalloc(&lhs_d, M * K * sizeof(half)));
  choreo::abend_true(cudaMalloc(&rhs_d, N * K * sizeof(half)));
  choreo::abend_true(cudaMalloc(&res_d, M * N * sizeof(half)));
  choreo::abend_true(cudaMemcpy(lhs_d, lhs.data(), M * K * sizeof(half), cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(rhs_d, rhs.data(), N * K * sizeof(half), cudaMemcpyHostToDevice));
  choreo::abend_true(cudaDeviceSynchronize());

  auto lhs_view_d = choreo::make_spanview<choreo::f16, 2>(lhs_d, {M, K});
  auto rhs_view_d = choreo::make_spanview<choreo::f16, 2>(rhs_d, {N, K});
  auto res_view_d = choreo::make_spanview<choreo::f16, 2>(res_d, {M, N});
  auto res = choreo::make_spandata<choreo::f16>(M, N);

  if (enable_timing) {
    choreo::TimerOption topt;
    topt.warmup = 10;
    topt.repeat = 50;
    auto avg_ms = choreo::timing(
        [&]() { matmul_global(lhs_view_d, rhs_view_d, res_view_d); cudaDeviceSynchronize(); },
        topt);
    std::cout << "Timing avg ms: " << avg_ms << "\n";
  }

  // run once on device and verify the actual device result
  matmul_global(lhs_view_d, rhs_view_d, res_view_d);
  choreo::abend_true(cudaMemcpy(res.data(), res_d, M * N * sizeof(half), cudaMemcpyDeviceToHost));
  choreo::abend_true(cudaDeviceSynchronize());

  float tolerance = 0.01f;
  auto rel_error = [](float ref, float got) {
    float abs_ref = std::abs(ref);
    float denom = abs_ref > 1e-6f ? abs_ref : 1.0f;
    return std::abs(ref - got) / denom;
  };
  // verfication
  for (size_t i = 0; i < res.shape()[0]; ++i)
    for (size_t j = 0; j < res.shape()[1]; ++j) {
      float ref = 0.0f;
      for (size_t k = 0; k < lhs.shape()[1]; ++k)
        ref += __half2float(lhs[i][k]) * __half2float(rhs[j][k]);
      float got = __half2float(res[i][j]);
      auto delta = rel_error(ref, got);
      // std::cout << "[" << i << ", " << j << "] " << __half2float(ref) << " <-> " << __half2float(res[i][j]) << ", delta: " << delta * 100 << "%\n";
      if (delta >= tolerance) {
        std::cout << "[" << i << ", " << j << "] " << ref << " <-> " << got << ", delta: " << delta * 100 << "%\n";
      }
      choreo::choreo_assert((delta < tolerance), "values are not equal.");
    }

  std::cout << "Test Passed\n" << std::endl;
}
