#ifndef ENABLE_DEBUG
#define ENABLE_DEBUG 1
#endif
__cok__ {
  template <typename T>
  __device__ __forceinline__ T SHFL_XOR(T var, int lane_mask, int width) {
    return __shfl_xor_sync(uint32_t(-1), var, lane_mask, width);
  }
  __device__ void compute_f32(
      const float a, const float b, const float dt_bias, const float a_log,
      const float softplus_beta, const float softplus_threshold,
      const float scale, float *__restrict__ q, float *__restrict__ k,
      float *__restrict__ v, float *__restrict__ o, const int BK, const int BV,
      bool USE_QK_L2NORM_IN_KERNEL) {
    int tid = threadIdx.x;
    // Compute g = -exp(A_log) * softplus(a + dt_bias)
    float x = a + dt_bias;
    float beta_x = softplus_beta * x;
    float softplus_x =
        beta_x < softplus_threshold
            ? (1.0 / softplus_beta) * logf(1.0 + expf(beta_x))
            : x;
    float g = -expf(a_log) * softplus_x;
    // Compute beta = sigmoid(b)
    float beta = __hdiv(1.0, __hadd(1.0, hexp(-b)));
    float beta = 1.0 / (1.0 + expf(-b));
  }
//   __device__ void computation(
//       const choreo::bf16 a, const choreo::bf16 b, const choreo::bf16 dt_bias,
//       const choreo::bf16 a_log, const choreo::bf16 softplus_beta,
//       const choreo::bf16 softplus_threshold, const choreo::f32 scale,
//       choreo::bf16 *__restrict__ q, choreo::bf16 *__restrict__ k,
//       choreo::bf16 *__restrict__ v, choreo::bf16 *__restrict__ o, const int BK,
//       const int BV, bool USE_QK_L2NORM_IN_KERNEL) {
