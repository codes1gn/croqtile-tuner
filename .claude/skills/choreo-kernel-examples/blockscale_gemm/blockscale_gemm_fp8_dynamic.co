// REQUIRES: TARGET-SM_90A
// RUN: choreo -gs -t cute -arch=sm_90a %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result
#define BLK_N 128
#define BLK_K 128

// TODO support symbolic representation for data size
__co__ void matmul(global f8_e4m3 [M, K] lhs,
                   global f32 [M, DIV_BLK_K] scale_a,
                   global f8_e4m3 [N, K] rhs,
                   global f32 [DIV_BLK_N, DIV_BLK_K] scale_b,
                   global f32 [M, N] output) {
  int WARP_M = 64, WARP_N = 128, WARP_K = 32;

  // each block handles 64x64 block with WGMMA
  // WGMMA requires 128 threads (4 warps x 32 threads/warp)
  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    shared f8_e4m3 [WARP_M, BLK_K] lhs_load_s;
    shared f8_e4m3 [WARP_N, BLK_K] rhs_load_s;

    parallel p by 1 : group-4 {
      mc = mma.fill.f16 0.0f; // mc = mma.fill.f32 0.0f;
      foreach {iv_k} in [cdiv(K, BLK_K)] {
        // load 64x32 to smem
        tma.copy.swiz<128>.zfill lhs.subspan(WARP_M, BLK_K).at(block_m, iv_k) => lhs_load_s;
        tma.copy.swiz<128> rhs.chunkat(block_n, iv_k) => rhs_load_s;

        // WGMMA requires 128 threads: 4 warps x 32 threads/warp
        foreach {iv_warp} in [cdiv(BLK_K, WARP_K)] {
          ma = mma.load.swiz<128> lhs_load_s.chunkat(_, iv_warp);
          mb = mma.load.swiz<128> rhs_load_s.chunkat(_, iv_warp);

          mma.row.row.scale mc, ma, mb, scale_a.subspan(WARP_M, 1).at(block_m, iv_k), scale_b.at(block_n, iv_k); // out of bound risk
        }
      }
      mma.store mc, output.subspan(WARP_M, WARP_N).at(block_m, block_n); // out of bound risk
    }
  }
}

int main(int argc, char** argv) {
  bool enable_timing = true;
  auto is_disable_timing_arg = [](const char* s) {
    const char* t = "--disable-timing";
    int i = 0;
    while (t[i] != '\0' && s[i] == t[i]) ++i;
    return t[i] == '\0' && s[i] == '\0';
  };
  for (int i = 1; i < argc; ++i) {
    if (is_disable_timing_arg(argv[i])) {
      enable_timing = false;
      break;
    }
  }

  const char* timing_env = std::getenv("CHOREO_DISABLE_TIMING");
  if (timing_env && timing_env[0] == '1' && timing_env[1] == '\0') {
    enable_timing = false;
  }

  // size_t M = 4096;
  // size_t N = 16384;
  // size_t K = 7168;
  size_t M = 4096;
  size_t N = 2048;
  size_t K = 2048;

  auto a_h = new __nv_fp8_e4m3[M * K];
  auto scale_a_h = new float[M * (K / BLK_K)];
  auto b_h = new __nv_fp8_e4m3[N * K];
  auto scale_b_h = new float[(N / BLK_N) * (K / BLK_K)];
  auto c_h = new float[M * N];

  for (size_t i = 0; i < M * K; i++) {
    a_h[i] = __nv_fp8_e4m3(static_cast<float>(rand() % 2));
  }
  for (size_t i = 0; i < M * (K / BLK_K); i++) {
    scale_a_h[i] = static_cast<float>(rand() % 2 + 1);
  }
  for (size_t i = 0; i < N * K; i++) {
    b_h[i] = __nv_fp8_e4m3(static_cast<float>(rand() % 2));
  }
  for (size_t i = 0; i < (N / BLK_N) * (K / BLK_K); i++) {
    scale_b_h[i] = static_cast<float>(rand() % 2 + 1);
  }
  for (size_t i = 0; i < M * N; i++) {
    c_h[i] = 0.0f;
  }

  __nv_fp8_e4m3 *a_d, *b_d;
  float *scale_a_d, *scale_b_d, *c_d;
  cudaMalloc(&a_d, M * K * sizeof(__nv_fp8_e4m3));
  cudaMalloc(&scale_a_d, M * (K / BLK_K) * sizeof(float));
  cudaMalloc(&b_d, N * K * sizeof(__nv_fp8_e4m3));
  cudaMalloc(&scale_b_d, (N / BLK_N) * (K / BLK_K) * sizeof(float));
  cudaMalloc(&c_d, M * N * sizeof(float));

  cudaMemcpy(a_d, a_h, M * K * sizeof(__nv_fp8_e4m3), cudaMemcpyHostToDevice);
  cudaMemcpy(scale_a_d, scale_a_h, M * (K / BLK_K) * sizeof(float), cudaMemcpyHostToDevice);
  cudaMemcpy(b_d, b_h, N * K * sizeof(__nv_fp8_e4m3), cudaMemcpyHostToDevice);
  cudaMemcpy(scale_b_d, scale_b_h, (N / BLK_N) * (K / BLK_K) * sizeof(float), cudaMemcpyHostToDevice);
  cudaMemcpy(c_d, c_h, M * N * sizeof(float), cudaMemcpyHostToDevice);

  auto lhd_d = choreo::make_spanview<choreo::f8_e4m3, 2>(a_d, {M, K});
  auto scale_a_d_view = choreo::make_spanview<choreo::f32, 2>(scale_a_d, {M, K / BLK_K});
  auto rhs_d = choreo::make_spanview<choreo::f8_e4m3, 2>(b_d, {N, K});
  auto scale_b_d_view = choreo::make_spanview<choreo::f32, 2>(scale_b_d, {N / BLK_N, K / BLK_K});
  auto out_d = choreo::make_spanview<choreo::f32, 2>(c_d, {M, N});
  matmul(lhd_d, scale_a_d_view, rhs_d, scale_b_d_view, out_d);

  cudaMemcpy(c_h, c_d, M * N * sizeof(float), cudaMemcpyDeviceToHost);

  // verification
  auto lhs = choreo::make_spanview<choreo::f8_e4m3, 2>(a_h, {M, K});
  auto scale_a = choreo::make_spanview<choreo::f32, 2>(scale_a_h, {M, K / BLK_K});
  auto rhs = choreo::make_spanview<choreo::f8_e4m3, 2>(b_h, {N, K});
  auto scale_b = choreo::make_spanview<choreo::f32, 2>(scale_b_h, {N / BLK_N, K / BLK_K});
  if (enable_timing) {
    choreo::TimerOption topt;
    topt.warmup = 10;                 // match static's warmup
    topt.repeat = 50;
    // time the actual matmul kernel (not a cheap CPU-side spanview)
    auto avg_ms = choreo::timing(
        [&]() { 
          auto lhd_d = choreo::make_spanview<choreo::f8_e4m3, 2>(a_d, {M, K});
          auto scale_a_d_view = choreo::make_spanview<choreo::f32, 2>(scale_a_d, {M, K / BLK_K});
          auto rhs_d = choreo::make_spanview<choreo::f8_e4m3, 2>(b_d, {N, K});
          auto scale_b_d_view = choreo::make_spanview<choreo::f32, 2>(scale_b_d, {N / BLK_N, K / BLK_K});
          auto out_d = choreo::make_spanview<choreo::f32, 2>(c_d, {M, N});
          matmul(lhd_d, scale_a_d_view, rhs_d, scale_b_d_view, out_d);
        },
        topt);
    std::cout << "Timing avg ms (matmul): " << avg_ms << "\n";
  }

  auto res = choreo::make_spanview<choreo::f32, 2>(c_h, {M, N});

  float base_tol = 0.3f;
  float rel_tol = 0.05f;
  // // verification (subset) with blockwise scaling
  // for (size_t i = 0; i < M; ++i)
  //   for (size_t j = 0; j < N; ++j) {
  //     float ref = 0.0f;
  //     for (size_t kb = 0; kb < (size_t)(K / BLK_K); ++kb) {
  //       float sa = choreo::to_f32(scale_a[(int)i][(int)kb]);
  //       float sb = choreo::to_f32(scale_b[(int)(j / BLK_N)][(int)kb]);
  //       for (size_t kk = 0; kk < (size_t)BLK_K; ++kk) {
  //         size_t k = kb * BLK_K + kk;
  //         ref += choreo::to_f32(lhs[(int)i][(int)k]) * sa *
  //                choreo::to_f32(rhs[(int)j][(int)k]) * sb;
  //       }
  //     }
  //     float got = choreo::to_f32(res[(int)i][(int)j]);
  //     float tol = base_tol + rel_tol * std::abs(ref);
  //     choreo::choreo_assert(std::abs(got - ref) <= tol, "values are not equal.");
  //   }

  // std::cout << "Test Passed\n" << std::endl;
}

// CHECK: Test Passed
