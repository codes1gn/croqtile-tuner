// REQUIRES: TARGET-GPU
// RUN: choreo -gs -t cute %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

// One representative kernel per WMMA data type, using the m16n16k16 tile shape.
// Each dtype exercises a distinct accumulator type and fill/store variant.

#define M 128
#define N 256
#define K 256

// ============ f16->f32 accumulation (m16n16k16) ============
__co__ auto matmul_f16_f32(f16 [M, K] lhs, f16 [K, N] rhs) {
  f32 [M, N] output;
  int MMA_M = 16, MMA_N = 16, MMA_K = 16;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.f32 0.0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }
  return output;
}

// ============ f16->f16 accumulation (m16n16k16) ============
__co__ auto matmul_f16_f16(f16 [M, K] lhs, f16 [K, N] rhs) {
  f16 [M, N] output;
  int MMA_M = 16, MMA_N = 16, MMA_K = 16;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill 0.0;
    parallel {g0, g1} by [2, 2] : group {
      mma.fill mc, 0.0;
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }
  return output;
}

// ============ bf16->f32 accumulation (m16n16k16) ============
__co__ auto matmul_bf16_f32(bf16 [M, K] lhs, bf16 [K, N] rhs) {
  f32 [M, N] output;
  int MMA_M = 16, MMA_N = 16, MMA_K = 16;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.f32 0.0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }
  return output;
}

// ============ s8->s32 accumulation (m16n16k16) ============
__co__ auto matmul_s8_s32(s8 [M, K] lhs, s8 [K, N] rhs) {
  s32 [M, N] output;
  int MMA_M = 16, MMA_N = 16, MMA_K = 16;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.s32 0.0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }
  return output;
}

// ============ u8->s32 accumulation (m16n16k16) ============
__co__ auto matmul_u8_s32(u8 [M, K] lhs, u8 [K, N] rhs) {
  s32 [M, N] output;
  int MMA_M = 16, MMA_N = 16, MMA_K = 16;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.s32 0.0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }
  return output;
}

// ============ tf32->f32 accumulation (m16n16k8) ============
__co__ auto matmul_tf32_f32(f32 [M, K] lhs, f32 [K, N] rhs) {
  f32 [M, N] output;
  int MMA_M = 16, MMA_N = 16, MMA_K = 8;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.f32 0.0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }
  return output;
}

#undef M
#undef N
#undef K

int main() {
  float tolerance = 0.005f;

  // --- f16->f32 ---
  {
    auto lhs = choreo::make_spandata<choreo::f16>(128, 256);
    auto rhs = choreo::make_spandata<choreo::f16>(256, 256);
    lhs.fill_random(1, 10); rhs.fill_random(1, 10);
    auto res = matmul_f16_f32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - res[i][j]) / ref);
        if (delta >= tolerance) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << res[i][j] << "\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }
    std::cout << "Test f16_f32 Passed\n";
  }

  // --- f16->f16 ---
  {
    auto lhs = choreo::make_spandata<choreo::f16>(128, 256);
    auto rhs = choreo::make_spandata<choreo::f16>(256, 256);
    lhs.fill_random(1, 10); rhs.fill_random(1, 10);
    auto res = matmul_f16_f16(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tolerance) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << __half2float(res[i][j]) << "\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }
    std::cout << "Test f16_f16 Passed\n";
  }

  // --- bf16->f32 ---
  {
    auto lhs = choreo::make_spandata<choreo::bf16>(128, 256);
    auto rhs = choreo::make_spandata<choreo::bf16>(256, 256);
    lhs.fill_random(1, 10); rhs.fill_random(1, 10);
    auto res = matmul_bf16_f32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - float(res[i][j])) / ref);
        if (delta >= tolerance) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << float(res[i][j]) << "\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }
    std::cout << "Test bf16_f32 Passed\n";
  }

  // --- s8->s32 ---
  {
    auto lhs = choreo::make_spandata<choreo::s8>(128, 256);
    auto rhs = choreo::make_spandata<choreo::s8>(256, 256);
    lhs.fill_random(1, 10); rhs.fill_random(1, 10);
    auto res = matmul_s8_s32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += int(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tolerance) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << int(res[i][j]) << "\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }
    std::cout << "Test s8_s32 Passed\n";
  }

  // --- u8->s32 ---
  {
    auto lhs = choreo::make_spandata<choreo::u8>(128, 256);
    auto rhs = choreo::make_spandata<choreo::u8>(256, 256);
    lhs.fill_random(1, 10); rhs.fill_random(1, 10);
    auto res = matmul_u8_s32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += int(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tolerance) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << int(res[i][j]) << "\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }
    std::cout << "Test u8_s32 Passed\n";
  }

  // --- tf32->f32 ---
  {
    auto lhs = choreo::make_spandata<choreo::f32>(128, 256);
    auto rhs = choreo::make_spandata<choreo::f32>(256, 256);
    lhs.fill_random(1.0f, 10.0f); rhs.fill_random(1.0f, 10.0f);
    auto res = matmul_tf32_f32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tolerance) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << __half2float(res[i][j]) << "\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }
    std::cout << "Test tf32_f32 Passed\n";
  }

  std::cout << "All Tests Passed\n" << std::endl;
}

// CHECK: Test f16_f32 Passed
// CHECK: Test f16_f16 Passed
// CHECK: Test bf16_f32 Passed
// CHECK: Test s8_s32 Passed
// CHECK: Test u8_s32 Passed
// CHECK: Test tf32_f32 Passed
// CHECK: All Tests Passed
