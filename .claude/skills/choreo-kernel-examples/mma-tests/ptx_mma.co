// REQUIRES: TARGET-GPU
// RUN: choreo -gs -t cute %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

// Representative PTX mma.sync cases: one per ISA variant / dtype combination.
// Covers m8n8 (Turing) and m16n8 (Ampere) tile families across major dtypes.

// ============ m8n8k4 f16->f16 (Turing, 4-group parallelism, mma.fill initializer) ============
#define M 128
#define N 256
#define K 64

__co__ auto mma_m8n8k4_f16_f16(f16 [M, K] lhs, f16 [K, N] rhs) {
  f16 [M, N] output;
  int MMA_M = 8, MMA_N = 8, MMA_K = 4;
  parallel {m, n} by [M / MMA_M / 4, N / MMA_N] : block {
    mc = mma.fill 0.0f;
    parallel {g0, g1} by [4, 1] : group {
      mma.fill mc, 1.5f;
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

#undef M
#undef N
#undef K

// ============ m8n8k16 s8->s32 (integer MMA, 2x2 group parallelism) ============
#define M 128
#define N 128
#define K 64

__co__ auto mma_m8n8k16_s8_s32(s8 [M, K] lhs, s8 [K, N] rhs) {
  s32 [M, N] output;
  int MMA_M = 8, MMA_N = 8, MMA_K = 16;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.s32 0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

#undef M
#undef N
#undef K

// ============ m16n8k8 f16->f32 (Ampere SM80+) ============
#define M 64
#define N 128
#define K 64

__co__ auto mma_m16n8k8_f16_f32(f16 [M, K] lhs, f16 [K, N] rhs) {
  f32 [M, N] output;
  int MMA_M = 16, MMA_N = 8, MMA_K = 8;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.f32 0.0f;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

// ============ m16n8k16 f16->f32 (larger K tile, same layout) ============
__co__ auto mma_m16n8k16_f16_f32(f16 [M, K] lhs, f16 [K, N] rhs) {
  f32 [M, N] output;
  int MMA_M = 16, MMA_N = 8, MMA_K = 16;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.f32 0.0f;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

// ============ m16n8k16 f16->f16 (f16 accumulator) ============
__co__ auto mma_m16n8k16_f16_f16(f16 [M, K] lhs, f16 [K, N] rhs) {
  f16 [M, N] output;
  int MMA_M = 16, MMA_N = 8, MMA_K = 16;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.f16 0.0f;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

#undef M
#undef N
#undef K

// ============ m16n8k8 bf16->f32 ============
#define M 128
#define N 256
#define K 128

__co__ auto mma_m16n8k8_bf16_f32(bf16 [M, K] lhs, bf16 [K, N] rhs) {
  f32 [M, N] output;
  int MMA_M = 16, MMA_N = 8, MMA_K = 8;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill.f32 0.0f;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

#undef M
#undef N
#undef K

// ============ m16n8k4 tf32->f32 ============
#define M 128
#define N 128
#define K 64

__co__ auto mma_m16n8k4_tf32_f32(f32 [M, K] lhs, f32 [K, N] rhs) {
  f32 [M, N] output;
  int MMA_M = 16, MMA_N = 8, MMA_K = 4;
  parallel {m, n} by [M / MMA_M / 2, N / MMA_N / 2] : block {
    mc = mma.fill 0.0f;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

#undef M
#undef N
#undef K

int main() {
  float tol_f = 0.005f;

  // --- m8n8k4 f16->f16 (init bias 1.5) ---
  {
    auto lhs = choreo::make_spandata<choreo::f16>(128, 64);
    auto rhs = choreo::make_spandata<choreo::f16>(64, 256);
    for (size_t i = 0; i < lhs.shape()[0]; ++i)
      for (size_t j = 0; j < lhs.shape()[1]; ++j)
        lhs[i][j] = __float2half(i * 0.02f + j * 0.1f);
    for (size_t i = 0; i < rhs.shape()[0]; ++i)
      for (size_t j = 0; j < rhs.shape()[1]; ++j)
        rhs[i][j] = __float2half(i * 0.1f + j * 0.03f);
    auto res = mma_m8n8k4_f16_f16(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 1.5f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tol_f) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << __half2float(res[i][j]) << "\n";
        choreo::choreo_assert((delta < tol_f), "values are not equal.");
      }
    std::cout << "Test m8n8k4_f16_f16 Passed\n";
  }

  // --- m8n8k16 s8->s32 (exact integer match) ---
  {
    auto lhs = choreo::make_spandata<choreo::s8>(128, 64);
    auto rhs = choreo::make_spandata<choreo::s8>(64, 128);
    lhs.fill_random(-10, 10); rhs.fill_random(-10, 10);
    auto res = mma_m8n8k16_s8_s32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        int32_t ref = 0;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += (lhs[i][k] * rhs[k][j]);
        if (ref != res[i][j]) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << res[i][j] << "\n";
        choreo::choreo_assert((ref == res[i][j]), "values are not equal.");
      }
    std::cout << "Test m8n8k16_s8_s32 Passed\n";
  }

  // --- m16n8k8 f16->f32 ---
  {
    auto lhs = choreo::make_spandata<choreo::f16>(64, 64);
    auto rhs = choreo::make_spandata<choreo::f16>(64, 128);
    for (size_t i = 0; i < lhs.shape()[0]; ++i)
      for (size_t j = 0; j < lhs.shape()[1]; ++j)
        lhs[i][j] = __float2half(i * 0.02f + j * 0.1f);
    for (size_t i = 0; i < rhs.shape()[0]; ++i)
      for (size_t j = 0; j < rhs.shape()[1]; ++j)
        rhs[i][j] = __float2half(i * 0.07f + j * 0.03f);
    auto res = mma_m16n8k8_f16_f32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - res[i][j]) / ref);
        if (delta >= 0.002f) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << res[i][j] << "\n";
        choreo::choreo_assert((delta < 0.002f), "values are not equal.");
      }
    std::cout << "Test m16n8k8_f16_f32 Passed\n";
  }

  // --- m16n8k16 f16->f32 ---
  {
    auto lhs = choreo::make_spandata<choreo::f16>(64, 64);
    auto rhs = choreo::make_spandata<choreo::f16>(64, 128);
    for (size_t i = 0; i < lhs.shape()[0]; ++i)
      for (size_t j = 0; j < lhs.shape()[1]; ++j)
        lhs[i][j] = __float2half(i * 0.02f + j * 0.1f);
    for (size_t i = 0; i < rhs.shape()[0]; ++i)
      for (size_t j = 0; j < rhs.shape()[1]; ++j)
        rhs[i][j] = __float2half(i * 0.07f + j * 0.03f);
    auto res = mma_m16n8k16_f16_f32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - res[i][j]) / ref);
        if (delta >= 0.002f) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << res[i][j] << "\n";
        choreo::choreo_assert((delta < 0.002f), "values are not equal.");
      }
    std::cout << "Test m16n8k16_f16_f32 Passed\n";
  }

  // --- m16n8k16 f16->f16 ---
  {
    auto lhs = choreo::make_spandata<choreo::f16>(64, 64);
    auto rhs = choreo::make_spandata<choreo::f16>(64, 128);
    for (size_t i = 0; i < lhs.shape()[0]; ++i)
      for (size_t j = 0; j < lhs.shape()[1]; ++j)
        lhs[i][j] = __float2half(i * 0.02f + j * 0.1f);
    for (size_t i = 0; i < rhs.shape()[0]; ++i)
      for (size_t j = 0; j < rhs.shape()[1]; ++j)
        rhs[i][j] = __float2half(i * 0.07f + j * 0.03f);
    auto res = mma_m16n8k16_f16_f16(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= 0.002f) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << __half2float(res[i][j]) << "\n";
        choreo::choreo_assert((delta < 0.002f), "values are not equal.");
      }
    std::cout << "Test m16n8k16_f16_f16 Passed\n";
  }

  // --- m16n8k8 bf16->f32 ---
  {
    auto lhs = choreo::make_spandata<choreo::bf16>(128, 128);
    auto rhs = choreo::make_spandata<choreo::bf16>(128, 256);
    for (size_t i = 0; i < lhs.shape()[0]; ++i)
      for (size_t j = 0; j < lhs.shape()[1]; ++j)
        lhs[i][j] = __float2bfloat16(i * 0.02f + j * 0.1f);
    for (size_t i = 0; i < rhs.shape()[0]; ++i)
      for (size_t j = 0; j < rhs.shape()[1]; ++j)
        rhs[i][j] = __float2bfloat16(i * 0.07f + j * 0.03f);
    auto res = mma_m16n8k8_bf16_f32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __bfloat162float(lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - res[i][j]) / ref);
        if (delta >= 0.002f) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << res[i][j] << "\n";
        choreo::choreo_assert((delta < 0.002f), "values are not equal.");
      }
    std::cout << "Test m16n8k8_bf16_f32 Passed\n";
  }

  // --- m16n8k4 tf32->f32 ---
  {
    auto lhs = choreo::make_spandata<choreo::f32>(128, 64);
    auto rhs = choreo::make_spandata<choreo::f32>(64, 128);
    lhs.fill_random(0.0f, 1.0f); rhs.fill_random(0.0f, 1.0f);
    auto res = mma_m16n8k4_tf32_f32(lhs.view(), rhs.view());
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += (lhs[i][k] * rhs[k][j]);
        float delta = std::abs((ref - res[i][j]) / ref);
        if (delta >= 0.002f) std::cout << "[" << i << "," << j << "] ref=" << ref << " got=" << res[i][j] << "\n";
        choreo::choreo_assert((delta < 0.002f), "values are not equal.");
      }
    std::cout << "Test m16n8k4_tf32_f32 Passed\n";
  }

  std::cout << "All Tests Passed\n" << std::endl;
}

// CHECK: Test m8n8k4_f16_f16 Passed
// CHECK: Test m8n8k16_s8_s32 Passed
// CHECK: Test m16n8k8_f16_f32 Passed
// CHECK: Test m16n8k16_f16_f32 Passed
// CHECK: Test m16n8k16_f16_f16 Passed
// CHECK: Test m16n8k8_bf16_f32 Passed
// CHECK: Test m16n8k4_tf32_f32 Passed
// CHECK: All Tests Passed
