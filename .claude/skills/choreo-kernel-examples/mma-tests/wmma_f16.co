// REQUIRES: TARGET-GPU
// RUN: choreo -gs -t cute %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

// Consolidated from: wmma_rr.co, wmma_mc_array.co, cmma_mc_array.co

// --- wmma_rr.co: row.row f16 matmul ---
#define RR_M 128
#define RR_N 256
#define RR_K 256

__co__ auto matmul_rr(f16 [RR_M, RR_K] lhs, f16 [RR_N, RR_K] rhs) {
  f16 [RR_M, RR_N] output;

  int MMA_M = 16, MMA_N = 16, MMA_K = 16;

  parallel {m, n} by [RR_M / MMA_M / 2, RR_N / MMA_N / 2] : block {
    mc = mma.fill 0.0;
    parallel {g0, g1} by [2, 2] : group {
      foreach k in RR_K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(n#g1, k);
        mma.row.row mc, ma, mb;
      }
      mma.store mc, output.chunkat(m#g0, n#g1);
    }
  }

  return output;
}

// --- wmma_mc_array.co: frag mc array indexing, f16 ---
#define MC_M 128
#define MC_N 256
#define MC_K 64

__co__ auto matmul_mc_array(f16 [MC_M, MC_K] lhs, f16 [MC_K, MC_N] rhs) {
  f16 [MC_M, MC_N] output;

  int MMA_M = 16, MMA_N = 16, MMA_K = 16;

  parallel {m, n} by [MC_M / MMA_M / 4, MC_N / MMA_N] : block {
    frag mc[2][3] {0.0};
    parallel {g0, g1} by [4, 1]: group {
      mma.fill mc[0][1], 0.0f;
      mma.fill mc[0][1], 0.0f;
      foreach k in MC_K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc[0][1], ma, mb;
      }
      mma.store mc[0][1], output.chunkat(m#g0, n#g1);
    }
  }

  return output;
}

// --- cmma_mc_array.co: frag.s32 mc array, s8 input ---
#define CMMA_M 128
#define CMMA_N 128
#define CMMA_K 64

__co__ auto matmul_cmma(s8 [CMMA_M, CMMA_K] lhs, s8 [CMMA_K, CMMA_N] rhs, int i) {
  s32 [CMMA_M, CMMA_N] output;

  int MMA_M = 8, MMA_N = 8, MMA_K = 16;
  parallel {m, n} by [CMMA_M / MMA_M / 2, CMMA_N / MMA_N / 2] : block {
    frag.s32 mc[1][2] {0};
    parallel {g0, g1} by [2, 2]: group {
      foreach k in CMMA_K / MMA_K {
        ma = mma.load lhs.chunkat(m#g0, k);
        mb = mma.load rhs.chunkat(k, n#g1);
        mma.row.col mc[0][i], ma, mb;
      }
      mma.store mc[0][i], output.chunkat(m#g0, n#g1);
    };
  }
  return output;
}

int main() {
  {
    auto lhs = choreo::make_spandata<choreo::f16>(RR_M, RR_K);
    auto rhs = choreo::make_spandata<choreo::f16>(RR_N, RR_K);
    lhs.fill_random(0, 1);
    rhs.fill_random(0, 1);

    auto res = matmul_rr(lhs.view(), rhs.view());

    float tolerance = 0.005f;
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        auto ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[j][k]);
        auto delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tolerance && i == 0 && j < 100)
          std::cout << "[" << i << ", " << j << "] " << ref << " <-> " << __half2float(res[i][j]) << ", delta: " << delta * 100 << "%\n";
        // choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }

    std::cout << "Test wmma_rr Passed\n" << std::endl;
  }

  {
    auto lhs = choreo::make_spandata<choreo::f16>(MC_M, MC_K);
    auto rhs = choreo::make_spandata<choreo::f16>(MC_K, MC_N);
    lhs.fill_random(1, 10);
    rhs.fill_random(1, 10);

    auto res = matmul_mc_array(lhs.view(), rhs.view());

    float tolerance = 0.002f;
    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        auto ref = 0.0f;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += __half2float(lhs[i][k] * rhs[k][j]);
        auto delta = std::abs((ref - __half2float(res[i][j])) / ref);
        if (delta >= tolerance)
          std::cout << "[" << i << ", " << j << "] " << ref << " <-> " << __half2float(res[i][j]) << ", delta: " << delta * 100 << "%\n";
        choreo::choreo_assert((delta < tolerance), "values are not equal.");
      }

    std::cout << "Test wmma_mc_array Passed\n" << std::endl;
  }

  {
    auto lhs = choreo::make_spandata<choreo::s8>(CMMA_M, CMMA_K);
    auto rhs = choreo::make_spandata<choreo::s8>(CMMA_K, CMMA_N);
    lhs.fill_random(-10, 10);
    rhs.fill_random(-10, 10);

    auto res = matmul_cmma(lhs.view(), rhs.view(), 1);

    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        int32_t ref = 0;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += (lhs[i][k] * rhs[k][j]);
        if (ref != res[i][j])
          std::cout << "[" << i << ", " << j << "] " << ref << " <-> " << (res[i][j]) << "\n";
        choreo::choreo_assert((ref == res[i][j]), "values are not equal.");
      }

    std::cout << "Test cmma_mc_array Passed\n" << std::endl;
  }
}

// CHECK: Test wmma_rr Passed
// CHECK: Test wmma_mc_array Passed
// CHECK: Test cmma_mc_array Passed
