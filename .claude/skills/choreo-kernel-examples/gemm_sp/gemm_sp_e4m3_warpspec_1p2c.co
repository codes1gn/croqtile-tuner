// REQUIRES: TARGET-SM_90A
// RUN: choreo -gs -t cute -arch=sm_90a --use-warpspec %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

#include <cstring>
#include <cstdlib>

#define H800_PCIE_PEAK_F8_TFLOPS 3026

#define MATMUL_DEFAULT_M 4096
#define MATMUL_DEFAULT_N 4096
#define MATMUL_DEFAULT_K 4096

#define WARP_M 64
#define TILE_M 128
#define WARP_N 256
#define TILE_K 64
#define WARP_K 64
#define SWIZ 32
#define STAGES 2
#define SPMM_META_TILE_COLS 8

template <typename T>
using SparsePolicyWGMMA = choreo::utils::SparsePolicyWGMMA<T>;

template <typename T>
void init_random_b(choreo::spanned_data<T, 2>& rhs, std::mt19937& gen) {
  std::uniform_real_distribution<float> dist(-1.0f, 1.0f);
  for (size_t j = 0; j < rhs.shape()[0]; ++j)
    for (size_t k = 0; k < rhs.shape()[1]; ++k) {
      float value = dist(gen);
      if (std::fabs(value) < 0.1f) value = (value < 0.0f ? -0.25f : 0.25f);
      rhs[j][k] = choreo::utils::from_f32<T>(value);
    }
}

__co__ void matmul_sp_e4m3(global f8_e4m3 [MATMUL_DEFAULT_M, MATMUL_DEFAULT_K / 2] lhs_packed, 
                            global u8 [MATMUL_DEFAULT_M, MATMUL_DEFAULT_K / 8] lhs_meta,
                            global f8_e4m3 [MATMUL_DEFAULT_N, MATMUL_DEFAULT_K] rhs,
                            global f16 [MATMUL_DEFAULT_M, MATMUL_DEFAULT_N] output) {
  parallel {block_m, block_n}
      by [cdiv(MATMUL_DEFAULT_M, TILE_M), cdiv(MATMUL_DEFAULT_N, WARP_N)] : block {
    shared event full[STAGES], empty[STAGES];
    shared f8_e4m3 [STAGES * TILE_M, TILE_K / 2] lhs_load_s;
    shared f8_e4m3 [STAGES * WARP_N, TILE_K] rhs_load_s;
    shared u8 [STAGES * TILE_M, SPMM_META_TILE_COLS] lhs_meta_s;
    shared f16 [TILE_M, WARP_N] output_s;

    parallel p by 3 : group-4 {
      inthreads.async (p == 0) {
        foreach {iv_k} in [cdiv(MATMUL_DEFAULT_K, TILE_K)] {
          stage = iv_k % STAGES;
          wait empty[stage];
          tma.copy.async<full[stage]>.swiz<SWIZ> lhs_packed
              .subspan(TILE_M, TILE_K / 2)
              .at(block_m, iv_k)
              => lhs_load_s.subspan(TILE_M, TILE_K / 2).at(stage, 0);
          tma.copy.async<full[stage]>.swiz<64> rhs
              .subspan(WARP_N, TILE_K)
              .at(block_n, iv_k)
              => rhs_load_s.subspan(WARP_N, TILE_K).at(stage, 0);
          trigger full[stage];
          // meta_f = dma.copy.async lhs_meta
          //       .subspan(TILE_M, SPMM_META_TILE_COLS)
          //       .at(block_m, iv_k)
          //       => lhs_meta_s
          //       .subspan(TILE_M, SPMM_META_TILE_COLS)
          //       .at(stage, 0);
          // wait meta_f;
        }
      }

      inthreads.async (p > 0) {
        mc = mma.fill.f16 0.0f;
        foreach {s} in [STAGES] { trigger empty[s]; }
        foreach {iv_k} in [cdiv(MATMUL_DEFAULT_K, TILE_K)] {
          stage = iv_k % STAGES;
          wait full[stage];
          foreach {iv_warp} in [cdiv(TILE_K, WARP_K)] {
            ma = mma.load.swiz<SWIZ> lhs_load_s
                .subspan(TILE_M, TILE_K / 2)
                .at(stage, 0)
                .subspan(WARP_M, TILE_K / 2)
                .at(p - 1, 0)
                .chunkat(_, iv_warp);
            mb = mma.load.swiz<64> rhs_load_s
                .subspan(WARP_N, TILE_K)
                .at(stage, 0)
                .chunkat(_, iv_warp);
            me = mma.load lhs_meta_s
                .subspan(TILE_M, SPMM_META_TILE_COLS)
                .at(stage, 0)
                .subspan(WARP_M, SPMM_META_TILE_COLS)
                .at(p - 1, 0)
                .chunkat(_, iv_warp);
            mma.row.row.sp mc, ma, mb, me;
          }
          mma.commit;
          trigger empty[stage];
        }
        mma.store mc, output_s.subspan(WARP_M, WARP_N).at(p - 1, 0);
      }
    }

    tma.copy output_s => output.subspan(TILE_M, WARP_N).at(block_m, block_n);
  }
}

int main(int argc, char** argv) {
  bool enable_timing = true;
  bool skip_verify = false;
  auto is_disable_timing_arg = [](const char* s) {
    const char* t = "--disable-timing";
    int i = 0;
    while (t[i] != '\0' && s[i] == t[i]) ++i;
    return t[i] == '\0' && s[i] == '\0';
  };
  auto is_skip_verify_arg = [](const char* s) {
    const char* t = "--skip-verify";
    int i = 0;
    while (t[i] != '\0' && s[i] == t[i]) ++i;
    return t[i] == '\0' && s[i] == '\0';
  };
  for (int i = 1; i < argc; ++i) {
    if (is_disable_timing_arg(argv[i])) {
      enable_timing = false;
      continue;
    }
    if (is_skip_verify_arg(argv[i])) {
      skip_verify = true;
    }
  }

  const char* timing_env = std::getenv("CHOREO_DISABLE_TIMING");
  if (timing_env && timing_env[0] == '1' && timing_env[1] == '\0') {
    enable_timing = false;
  }

  const char* skip_verify_env = std::getenv("CHOREO_SKIP_VERIFY");
  if (skip_verify_env && skip_verify_env[0] == '1' && skip_verify_env[1] == '\0') {
    skip_verify = true;
  }

  size_t M = MATMUL_DEFAULT_M;
  size_t N = MATMUL_DEFAULT_N;
  size_t K = MATMUL_DEFAULT_K;

  std::mt19937 gen(42);
  auto lhs_dense = choreo::make_spandata<choreo::f8_e4m3>(M, K);
  auto lhs_packed = choreo::make_spandata<choreo::f8_e4m3>(M, K / 2);
  auto lhs_meta = choreo::make_spandata<choreo::u8>(M, K / 8);
  auto rhs = choreo::make_spandata<choreo::f8_e4m3>(N, K);
  auto res = choreo::make_spandata<choreo::f16>(M, N);
  SparsePolicyWGMMA<choreo::f8_e4m3>::init_structured_sparse_A(lhs_dense, gen);
  init_random_b<choreo::f8_e4m3>(rhs, gen);
  SparsePolicyWGMMA<choreo::f8_e4m3>::encode(lhs_dense, lhs_packed, lhs_meta);

  __nv_fp8_e4m3 *a_d = nullptr, *b_d = nullptr;
  half *c_d = nullptr;
  choreo::abend_true(cudaMalloc(&a_d, (M * K / 2) * sizeof(__nv_fp8_e4m3) + (M * K / 8) * sizeof(u8)));
  choreo::abend_true(cudaMalloc(&b_d, N * K * sizeof(__nv_fp8_e4m3)));
  choreo::abend_true(cudaMalloc(&c_d, M * N * sizeof(half)));
  
  choreo::abend_true(cudaMemcpy(a_d, lhs_packed.data(), (M * K / 2) * sizeof(__nv_fp8_e4m3), cudaMemcpyHostToDevice));
  u8* meta_d = (u8*)((__nv_fp8_e4m3*)a_d + M * K / 2);
  choreo::abend_true(cudaMemcpy(meta_d, lhs_meta.data(), (M * K / 8) * sizeof(u8), cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(b_d, rhs.data(), N * K * sizeof(__nv_fp8_e4m3), cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(c_d, res.data(), M * N * sizeof(half), cudaMemcpyHostToDevice));
  choreo::abend_true(cudaDeviceSynchronize());

  auto lhs_packed_d = choreo::make_spanview<choreo::f8_e4m3, 2>(a_d, {M, K / 2});
  auto lhs_meta_d = choreo::make_spanview<choreo::u8, 2>(meta_d, {M, K / 8});
  auto rhs_d = choreo::make_spanview<choreo::f8_e4m3, 2>(b_d, {N, K});
  auto res_d = choreo::make_spanview<choreo::f16, 2>(c_d, {M, N});

  if (enable_timing) {
    int warmup = 10;
    int repeat = 500;
    const char* warmup_env = std::getenv("CHOREO_TIMING_WARMUP");
    const char* repeat_env = std::getenv("CHOREO_TIMING_REPEAT");
    if (warmup_env) {
      int value = std::atoi(warmup_env);
      if (value >= 0) warmup = value;
    }
    if (repeat_env) {
      int value = std::atoi(repeat_env);
      if (value > 0) repeat = value;
    }
    choreo::TimerOption topt;
    topt.warmup = warmup;
    topt.repeat = repeat;

    auto avg_ms = choreo::timing([&]() { matmul_sp_e4m3(lhs_packed_d, lhs_meta_d, rhs_d, res_d); }, topt);
    double flops = 2.0 * double(M) * double(N) * double(K);
    double tflops = (flops / (avg_ms / 1000.0)) / 1e12;
    std::cout << "TFLOPS: " << tflops << "\n";

    double eff = (tflops / H800_PCIE_PEAK_F8_TFLOPS) * 100.0;
    std::cout << "HW efficiency: " << eff << "%\n";
  }

  matmul_sp_e4m3(lhs_packed_d, lhs_meta_d, rhs_d, res_d);

  choreo::abend_true(cudaMemcpy(res.data(), c_d, M * N * sizeof(half), cudaMemcpyDeviceToHost));
  choreo::abend_true(cudaDeviceSynchronize());

  int errors = 0;
  float tolerance = 0.5f;
  for (size_t i = 0; i < 128; ++i) {
    for (size_t j = 0; j < 256; ++j) {
      float ref = 0.0f;
      for (size_t k = 0; k < K; ++k)
        ref += choreo::to_f32(lhs_dense[i][k]) * choreo::to_f32(rhs[j][k]);
      float got = res[i][j];
      float diff = std::abs(got - ref);
      if (diff > tolerance) {
        if (errors < 8)
          std::cout << "mismatch at (" << i << ", " << j << ") gpu=" << got << " ref=" << ref << " diff=" << diff << "\n";
        ++errors;
      }
    }
  }
  std::cout << "f16_sp: " << errors << " errors\n";
  choreo::choreo_assert(errors == 0, "Sparse WGMMA f16 failed");
  std::cout << "Test Passed\n";
  std::cout << "Test Passed\n" << std::endl;
}

// CHECK: Test Passed
