// REQUIRES: TARGET-SM_90
// RUN: choreo -gs -t cute -arch=sm_90a %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

// Comprehensive mma.store masking test: covers auto-detected masking
// and explicit mma.store.mask across aligned and non-aligned sizes.
//
// Problem sizes exercised per kernel:
//   aligned  : 128x128  (full store, no mask needed)
//   M-tail   : 100x128  (row mask only)
//   N-tail   : 128x100  (col mask only)
//   M+N-tail : 100x100  (row+col mask)
//   big-MN   : 300x300  (multi-block with tail)

#include <cstring>
#include <cstdlib>

#define WARP_M 64
#define WARP_N 128
#define WARP_K 16
#define TILE_K 64
#define SWIZ 128

// --- Kernel 1: auto-detected masking ---
__co__ void matmul_auto(global f16 [M, K] lhs, global f16 [N, K] rhs,
                        global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    shared f16 [WARP_M, TILE_K] lhs_s;
    shared f16 [WARP_N, TILE_K] rhs_s;
    mc = mma.fill.f16 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      tma.copy.swiz<SWIZ> lhs
        .subspan(WARP_M, TILE_K).at(block_m, iv_k) => lhs_s;
      tma.copy.swiz<SWIZ> rhs
        .subspan(WARP_N, TILE_K).at(block_n, iv_k) => rhs_s;
      foreach {iv_wk} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.load.swiz<SWIZ> lhs_s.chunkat(_, iv_wk);
          mb = mma.load.swiz<SWIZ> rhs_s.chunkat(_, iv_wk);
          mma.row.row mc, ma, mb;
        }
      }
    }
    mma.store mc, output.subspan(WARP_M, WARP_N).at(block_m, block_n);
  }
}

// --- Kernel 2: explicit mma.store.mask ---
__co__ void matmul_explicit(global f16 [M, K] lhs, global f16 [N, K] rhs,
                            global f16 [M, N] output) {
  parallel {block_m, block_n} by [cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    shared f16 [WARP_M, TILE_K] lhs_s;
    shared f16 [WARP_N, TILE_K] rhs_s;
    mc = mma.fill.f16 0.0f;
    foreach {iv_k} in [cdiv(K, TILE_K)] {
      tma.copy.swiz<SWIZ> lhs
        .subspan(WARP_M, TILE_K).at(block_m, iv_k) => lhs_s;
      tma.copy.swiz<SWIZ> rhs
        .subspan(WARP_N, TILE_K).at(block_n, iv_k) => rhs_s;
      foreach {iv_wk} in [cdiv(TILE_K, WARP_K)] {
        parallel p by 1 : group-4 {
          ma = mma.load.swiz<SWIZ> lhs_s.chunkat(_, iv_wk);
          mb = mma.load.swiz<SWIZ> rhs_s.chunkat(_, iv_wk);
          mma.row.row mc, ma, mb;
        }
      }
    }
    row_guard = M - block_m * WARP_M;
    col_guard = N - block_n * WARP_N;
    mma.store.mask mc,
      output.subspan(WARP_M, WARP_N).at(block_m, block_n),
      row_guard, col_guard;
  }
}

// --- Test harness ---

static bool run_auto(const char* label, size_t m, size_t n, size_t k) {
  auto lhs_h = choreo::make_spandata<choreo::f16>(m, k);
  auto rhs_h = choreo::make_spandata<choreo::f16>(n, k);
  auto res_h = choreo::make_spandata<choreo::f16>(m, n);
  lhs_h.fill_random(0, 2);
  rhs_h.fill_random(0, 2);
  res_h.fill(0.0f);

  half *a_d = nullptr, *b_d = nullptr, *c_d = nullptr;
  choreo::abend_true(cudaMalloc(&a_d, m * k * sizeof(half)));
  choreo::abend_true(cudaMalloc(&b_d, n * k * sizeof(half)));
  choreo::abend_true(cudaMalloc(&c_d, m * n * sizeof(half)));
  choreo::abend_true(cudaMemcpy(a_d, lhs_h.data(), m * k * sizeof(half),
                                cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(b_d, rhs_h.data(), n * k * sizeof(half),
                                cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemset(c_d, 0, m * n * sizeof(half)));
  choreo::abend_true(cudaDeviceSynchronize());

  matmul_auto(
      choreo::make_spanview<choreo::f16, 2>(a_d, {m, k}),
      choreo::make_spanview<choreo::f16, 2>(b_d, {n, k}),
      choreo::make_spanview<choreo::f16, 2>(c_d, {m, n}));

  choreo::abend_true(cudaMemcpy(res_h.data(), c_d, m * n * sizeof(half),
                                cudaMemcpyDeviceToHost));
  choreo::abend_true(cudaDeviceSynchronize());
  cudaFree(a_d); cudaFree(b_d); cudaFree(c_d);

  auto lhs_view = lhs_h.view();
  auto rhs_view = rhs_h.view();
  auto res_view = res_h.view();
  float tolerance = 0.05f;
  size_t mismatch = 0;
  for (size_t i = 0; i < m; ++i)
    for (size_t j = 0; j < n; ++j) {
      float ref = 0.0f;
      for (size_t ki = 0; ki < k; ++ki)
        ref += __half2float(lhs_view[i][ki] * rhs_view[j][ki]);
      float got = __half2float(res_view[i][j]);
      float abs_ref = std::abs(ref);
      float denom = abs_ref > 1e-6f ? abs_ref : 1.0f;
      if (std::abs(ref - got) / denom >= tolerance) {
        if (mismatch < 5)
          std::cout << "  [" << i << "," << j << "] ref=" << ref
                    << " got=" << got << "\n";
        ++mismatch;
      }
    }
  std::cout << label << " M=" << m << " N=" << n << " K=" << k << ": "
            << (mismatch == 0 ? "PASS" : "FAIL") << "\n";
  return mismatch == 0;
}

static bool run_explicit(const char* label, size_t m, size_t n, size_t k) {
  auto lhs_h = choreo::make_spandata<choreo::f16>(m, k);
  auto rhs_h = choreo::make_spandata<choreo::f16>(n, k);
  auto res_h = choreo::make_spandata<choreo::f16>(m, n);
  lhs_h.fill_random(0, 2);
  rhs_h.fill_random(0, 2);
  res_h.fill(0.0f);

  half *a_d = nullptr, *b_d = nullptr, *c_d = nullptr;
  choreo::abend_true(cudaMalloc(&a_d, m * k * sizeof(half)));
  choreo::abend_true(cudaMalloc(&b_d, n * k * sizeof(half)));
  choreo::abend_true(cudaMalloc(&c_d, m * n * sizeof(half)));
  choreo::abend_true(cudaMemcpy(a_d, lhs_h.data(), m * k * sizeof(half),
                                cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemcpy(b_d, rhs_h.data(), n * k * sizeof(half),
                                cudaMemcpyHostToDevice));
  choreo::abend_true(cudaMemset(c_d, 0, m * n * sizeof(half)));
  choreo::abend_true(cudaDeviceSynchronize());

  matmul_explicit(
      choreo::make_spanview<choreo::f16, 2>(a_d, {m, k}),
      choreo::make_spanview<choreo::f16, 2>(b_d, {n, k}),
      choreo::make_spanview<choreo::f16, 2>(c_d, {m, n}));

  choreo::abend_true(cudaMemcpy(res_h.data(), c_d, m * n * sizeof(half),
                                cudaMemcpyDeviceToHost));
  choreo::abend_true(cudaDeviceSynchronize());
  cudaFree(a_d); cudaFree(b_d); cudaFree(c_d);

  auto lhs_view = lhs_h.view();
  auto rhs_view = rhs_h.view();
  auto res_view = res_h.view();
  float tolerance = 0.05f;
  size_t mismatch = 0;
  for (size_t i = 0; i < m; ++i)
    for (size_t j = 0; j < n; ++j) {
      float ref = 0.0f;
      for (size_t ki = 0; ki < k; ++ki)
        ref += __half2float(lhs_view[i][ki] * rhs_view[j][ki]);
      float got = __half2float(res_view[i][j]);
      float abs_ref = std::abs(ref);
      float denom = abs_ref > 1e-6f ? abs_ref : 1.0f;
      if (std::abs(ref - got) / denom >= tolerance) {
        if (mismatch < 5)
          std::cout << "  [" << i << "," << j << "] ref=" << ref
                    << " got=" << got << "\n";
        ++mismatch;
      }
    }
  std::cout << label << " M=" << m << " N=" << n << " K=" << k << ": "
            << (mismatch == 0 ? "PASS" : "FAIL") << "\n";
  return mismatch == 0;
}

int main() {
  bool ok = true;

  std::cout << "=== auto-detect masking ===" << std::endl;
  ok &= run_auto("aligned ", 128, 128, 64);
  ok &= run_auto("M-tail  ", 100, 128, 64);
  ok &= run_auto("N-tail  ", 128, 100, 64);
  ok &= run_auto("MN-tail ", 100, 100, 64);
  ok &= run_auto("big-MN  ", 300, 300, 64);

  std::cout << "=== explicit mma.store.mask ===" << std::endl;
  ok &= run_explicit("aligned ", 128, 128, 64);
  ok &= run_explicit("M-tail  ", 100, 128, 64);
  ok &= run_explicit("N-tail  ", 128, 100, 64);
  ok &= run_explicit("MN-tail ", 100, 100, 64);
  ok &= run_explicit("big-MN  ", 300, 300, 64);

  if (ok) std::cout << "Test Passed" << std::endl;
  else    return 1;
}

// CHECK: === auto-detect masking ===
// CHECK: aligned  M=128 N=128 K=64: PASS
// CHECK: M-tail   M=100 N=128 K=64: PASS
// CHECK: N-tail   M=128 N=100 K=64: PASS
// CHECK: MN-tail  M=100 N=100 K=64: PASS
// CHECK: big-MN   M=300 N=300 K=64: PASS
// CHECK: === explicit mma.store.mask ===
// CHECK: aligned  M=128 N=128 K=64: PASS
// CHECK: M-tail   M=100 N=128 K=64: PASS
// CHECK: N-tail   M=128 N=100 K=64: PASS
// CHECK: MN-tail  M=100 N=100 K=64: PASS
// CHECK: big-MN   M=300 N=300 K=64: PASS
// CHECK: Test Passed
