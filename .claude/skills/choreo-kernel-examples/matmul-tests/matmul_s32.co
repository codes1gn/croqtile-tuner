// REQUIRES: TARGET-GPU
// RUN: choreo -gs -t cute %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

// Consolidated from: matmul.co, matmul-dma.co, matmul-pipelined-2.co

// --- matmul.co: scalar loop, s32 ---
__co__ s32 [128, 256] matmul_basic(s32 [128, 256] lhs, s32 [256, 256] rhs) {
  s32[lhs.span(0), rhs.span(1)] output;

  parallel p by 16, q by 64 {
    foreach index = {m, n, k} in [128 / #p, 256 / #q, 256]
      output.at(m#p, n#q) += lhs.at(m#p, k) * rhs.at(k, n#q);
  }
  return output;
}

// --- matmul-dma.co: shared memory DMA tiles, s32 ---
__co__ s32 [128, 256] matmul_dma(s32 [128, 256] lhs, s32 [256, 256] rhs) {
  s32[lhs.span(0), rhs.span(1)] output;
  parallel {px, py} by [8, 16] {
    foreach {tile_k} in [16] {
      lhs_load = dma.copy lhs.chunkat(px, tile_k) => local;
      rhs_load = dma.copy rhs.chunkat(tile_k, py) => local;
      parallel {qx, qy} by [16, 16] {
        foreach k in [256 / #tile_k] {
          output.at(px#qx, py#qy) += lhs_load.data.at(qx, k) * rhs_load.data.at(k, qy);
        }
      }
    }
  }

  return output;
}

// --- matmul-pipelined-2.co: double-buffered shared memory pipeline, s32 ---
#define PIPE_M 128
#define PIPE_N 256
#define PIPE_K 256

__co__ auto matmul_pipelined(s32 [PIPE_M, PIPE_K] lhs, s32 [PIPE_K, PIPE_N] rhs) {
  s32 [lhs.span(0), rhs.span(1)] output;

  parallel {px, py} by [8, 16] : block
    parallel {qx, qy} by [16, 16] : thread {
    with tile_k in 16 {
      lf0 = dma.copy lhs.chunkat(px, tile_k) => shared;
      rf0 = dma.copy rhs.chunkat(tile_k, py) => shared;

      lf1 = dma.any;
      rf1 = dma.any;

      foreach tile_k(1:) {
        lf1 = dma.copy lhs.chunkat(px, tile_k) => shared;
        rf1 = dma.copy rhs.chunkat(tile_k, py) => shared;

        foreach k in [256 / #tile_k]
          output.at(px#qx, py#qy) += lf0.data.at(qx, k) * rf0.data.at(k, qy);

        swap(lf0, lf1);
        swap(rf0, rf1);
      }

      foreach k in [256 / #tile_k]
        output.at(px#qx, py#qy) += lf0.data.at(qx, k) * rf0.data.at(k, qy);
    }
  }

  return output;
}

int main() {
  {
    auto lhs = choreo::make_spandata<choreo::s32>(128, 256);
    auto rhs = choreo::make_spandata<choreo::s32>(256, 256);
    lhs.fill_random(-10, 10);
    rhs.fill_random(-10, 10);

    auto res = matmul_basic(lhs.view(), rhs.view());

    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        int ref = 0;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += lhs[i][k] * rhs[k][j];
        choreo::choreo_assert(ref == res[i][j], "values are not equal.");
      }

    std::cout << "Test basic Passed\n" << std::endl;
  }

  {
    choreo::s32 a[128][256] = {0};
    choreo::s32 b[256][256] = {0};
    auto lhs_data = choreo::make_spanview<2, choreo::s32>((int*)a, {128, 256});
    auto rhs_data = choreo::make_spanview<2, choreo::s32>((int*)b, {256, 256});
    lhs_data.fill_random(-10, 10);
    rhs_data.fill_random(-10, 10);

    auto res = matmul_dma(lhs_data, rhs_data);

    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        int ref = 0;
        for (size_t k = 0; k < lhs_data.shape()[1]; ++k)
          ref += a[i][k] * b[k][j];
        choreo::choreo_assert(ref == res[i][j], "values are not equal.");
      }

    std::cout << "Test dma Passed\n" << std::endl;
  }

  {
    auto lhs = choreo::make_spandata<choreo::s32>(PIPE_M, PIPE_K);
    auto rhs = choreo::make_spandata<choreo::s32>(PIPE_K, PIPE_N);
    lhs.fill_random(-10, 10);
    rhs.fill_random(-10, 10);

    auto res = matmul_pipelined(lhs.view(), rhs.view());

    for (size_t i = 0; i < res.shape()[0]; ++i)
      for (size_t j = 0; j < res.shape()[1]; ++j) {
        int ref = 0;
        for (size_t k = 0; k < lhs.shape()[1]; ++k)
          ref += lhs[i][k] * rhs[k][j];
        choreo::choreo_assert(ref == res[i][j], "values are not equal.");
      }

    std::cout << "Test pipelined Passed\n" << std::endl;
  }
}

// CHECK: Test basic Passed
// CHECK: Test dma Passed
// CHECK: Test pipelined Passed
