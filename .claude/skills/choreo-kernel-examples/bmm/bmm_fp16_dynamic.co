// REQUIRES: TARGET-SM_90A
// RUN: choreo -gs -t cute -arch=sm_90a %s -o %s.cute.result && bash %s.cute.result --execute | FileCheck --match-full-lines %s && rm -f %s.cute.result

// TODO support symbolic representation for data size
__co__ void bmm(global bf16 [B, M, K] lhs,
               global bf16 [B, N, K] rhs,
               global f32 [B, M, N] output) {
  int WARP_M = 64, WARP_N = 64, WARP_K = 16, TILE_SIZE_K = 64;

  // each block handles 64x64 block with WGMMA
  // WGMMA requires 128 threads (4 warps x 32 threads/warp)
  parallel {block_b, block_m, block_n} by [B, cdiv(M, WARP_M), cdiv(N, WARP_N)] : block {
    shared bf16 [1, WARP_M, TILE_SIZE_K] lhs_load_s;
    shared bf16 [1, WARP_N, TILE_SIZE_K] rhs_load_s;
    shared f32 [WARP_M, WARP_N] output_s {0.0f};

    parallel p by 1 : group-4 {
      foreach {iv_k} in [cdiv(K, TILE_SIZE_K)] {
        // load 64x128 and 128x64 to smem
        tma.copy.swizzle<128> lhs.subspan(1, WARP_M, TILE_SIZE_K).at(block_b, block_m, iv_k) => lhs_load_s;
        tma.copy.swizzle<128> rhs.subspan(1, WARP_N, TILE_SIZE_K).at(block_b, block_n, iv_k) => rhs_load_s;
        mc_k = mma.fill.f32 0.0f;
        // WGMMA requires 128 threads: 4 warps x 32 threads/warp
        foreach {iv_warp} in [cdiv(TILE_SIZE_K, WARP_K)] {
          ma = mma.load.swizzle<128> lhs_load_s.span_as([WARP_M, TILE_SIZE_K]).chunkat(_, iv_warp);
          mb = mma.load.swizzle<128> rhs_load_s.span_as([WARP_N, TILE_SIZE_K]).chunkat(_, iv_warp);
          mma.row.row mc_k, ma, mb;
        }
        mma.store mc_k, output_s;
        sync.shared;
        parallel {m, n} by [WARP_M, 2] : thread {
          foreach {ni} in [WARP_N / 2] {
            if (block_m # m < M && block_n # (n # ni) < N) {
              output.at(block_b, block_m # m, block_n # (n # ni)) += output_s.at(m, n # ni);
            }
          }
        }
        sync.shared;
      }
    }
  }
}

int main(int argc, char** argv) {
  bool enable_timing = true;
  auto is_disable_timing_arg = [](const char* s) {
    const char* t = "--disable-timing";
    int i = 0;
    while (t[i] != '\0' && s[i] == t[i]) ++i;
    return t[i] == '\0' && s[i] == '\0';
  };
  for (int i = 1; i < argc; ++i) {
    if (is_disable_timing_arg(argv[i])) {
      enable_timing = false;
      break;
    }
  }

  const char* timing_env = std::getenv("CHOREO_DISABLE_TIMING");
  if (timing_env && timing_env[0] == '1' && timing_env[1] == '\0') {
    enable_timing = false;
  }

  size_t B = 3;
  size_t M = 127;
  size_t N = 128;
  size_t K = 128;

  auto a_h = new __nv_bfloat16[B * M * K];
  auto b_h = new __nv_bfloat16[B * N * K];
  auto b_h_logical = new __nv_bfloat16[B * K * N];
  auto c_h = new float[B * M * N];

  choreo::utils::fill_random(a_h, B * M * K, __nv_bfloat16(0.0f), __nv_bfloat16(1.0f));
  choreo::utils::fill_random(b_h_logical, B * K * N, __nv_bfloat16(0.0f), __nv_bfloat16(1.0f));
  for (size_t b = 0; b < B; ++b) {
    for (size_t k = 0; k < K; ++k) {
      for (size_t n = 0; n < N; ++n) {
        b_h[(b * N + n) * K + k] = b_h_logical[(b * K + k) * N + n];
      }
    }
  }
  // choreo::utils::fill_n(c_h, c_h + B * M * N, 0.0f);

  __nv_bfloat16 *a_d, *b_d;
  float *c_d;
  cudaMalloc(&a_d, B * M * K * sizeof(__nv_bfloat16));
  cudaMalloc(&b_d, B * N * K * sizeof(__nv_bfloat16));
  cudaMalloc(&c_d, B * M * N * sizeof(float));

  cudaMemcpy(a_d, a_h, B * M * K * sizeof(__nv_bfloat16), cudaMemcpyHostToDevice);
  cudaMemcpy(b_d, b_h, B * N * K * sizeof(__nv_bfloat16), cudaMemcpyHostToDevice);
  cudaMemcpy(c_d, c_h, B * M * N * sizeof(float), cudaMemcpyHostToDevice);

  auto lhs_d = choreo::make_spanview<choreo::bf16, 3>(a_d, {B, M, K});
  auto rhs_d = choreo::make_spanview<choreo::bf16, 3>(b_d, {B, N, K});
  auto out_d = choreo::make_spanview<choreo::f32, 3>(c_d, {B, M, N});
  if (enable_timing) {
    choreo::TimerOption topt;
      topt.warmup = 10;
      topt.repeat = 50;
      auto avg_ms = choreo::timing(
          [&]() {
            cudaMemset(c_d, 0, B * M * N * sizeof(float));
            bmm(lhs_d, rhs_d, out_d);
          },
          topt);
      std::cout << "Timing avg ms: " << avg_ms << "\n";
  }

  cudaMemset(c_d, 0, B * M * N * sizeof(float));
  bmm(lhs_d, rhs_d, out_d);

  cudaMemcpy(c_h, c_d, B * M * N * sizeof(float), cudaMemcpyDeviceToHost);

  // verification
  auto lhs = choreo::make_spanview<choreo::bf16, 3>(a_h, {B, M, K});
  auto rhs = choreo::make_spanview<choreo::bf16, 3>(b_h_logical, {B, K, N});
  auto res = choreo::make_spanview<choreo::f32, 3>(c_h, {B, M, N});

  float base_tol = 0.3f;
  float rel_tol = 0.05f;
  for (size_t b = 0; b < B; ++b)
    for (size_t i = 0; i < M; ++i)
      for (size_t j = 0; j < N; ++j) {
        float ref = 0.0f;
        for (size_t k = 0; k < K; ++k) {
          ref += choreo::to_f32(lhs[(int)b][(int)i][(int)k]) *
                 choreo::to_f32(rhs[(int)b][(int)k][(int)j]);
        }
        float got = choreo::to_f32(res[(int)b][(int)i][(int)j]);
        float tol = base_tol + rel_tol * std::abs(ref);
        choreo::choreo_assert(std::abs(got - ref) <= tol, "values are not equal.");
      }

  std::cout << "Test Passed\n" << std::endl;
}

// CHECK: Test Passed

