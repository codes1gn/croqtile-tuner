int run_case_k32_bf16() {
  const int M = 64, N = 64, K = 64, META_K = 32;
  std::mt19937 gen(42);
  auto lhs_dense = choreo::make_spandata<choreo::bf16>(M, K);
  auto rhs = choreo::make_spandata<choreo::bf16>(N, K);
  SparsePolicyK32<choreo::bf16>::init_structured_sparse_A(lhs_dense, gen);
  rhs.fill_random(-1.0f, 1.0f);
  auto lhs_packed = choreo::make_spandata<choreo::bf16>(M, K / 2);
  auto lhs_meta = choreo::make_spandata<choreo::u32>(M, K / META_K);
  SparsePolicyK32<choreo::bf16>::encode(lhs_dense, lhs_packed, lhs_meta);
  auto res = matmul_sp_k32_bf16(lhs_packed.view(), lhs_meta.view(), rhs.view());
  float tolerance = 0.1f;
  int errors = 0;
  for (size_t i = 0; i < (size_t)M; ++i)
    for (size_t j = 0; j < (size_t)N; ++j) {
      float ref = 0.0f;
      for (size_t k = 0; k < (size_t)K; ++k)
        ref += choreo::to_f32(lhs_dense[i][k]) * choreo::to_f32(rhs[j][k]);
      if (std::abs(res[i][j] - ref) >= tolerance) errors++;
    }
  std::cout << "k32_bf16: " << errors << " errors\n";
  return errors;
}

int main() {
  int errors = 0;
  errors += run_case_k16_f16();
  errors += run_case_k16_bf16();
  errors += run_case_k32_f16();
  errors += run_case_k32_bf16();
  if (errors > 0) {
    std::cout << "FAILED: " << errors << " errors\n";
    return 1;
  }
  std::cout << "Test Passed\n";
  return 0;
}

// CHECK: Test Passed
