def detect_topic(query: str) -> str:
    q = query.lower()
    for keyword, topic in KEYWORD_MAP.items():
        if keyword in q:
            return topic
    return "generic"


def main():
    args = sys.argv[1:]
    topic = None
    query = ""

    i = 0
    while i < len(args):
        if args[i] == "--topic" and i + 1 < len(args):
            topic = args[i + 1]
            i += 2
        else:
            query += " " + args[i]
            i += 1

    query = query.strip()

    if topic is None:
        if not query:
            topic = "generic"
        else:
            topic = detect_topic(query)

    if topic not in RESULTS_DB:
        known = ", ".join(sorted(RESULTS_DB.keys()))
        print(
            json.dumps(
                {"error": f"Unknown topic '{topic}'. Known topics: {known}"}
            )
        )
        sys.exit(0)

    results = RESULTS_DB[topic]
    print(json.dumps(results, indent=2))


if __name__ == "__main__":
    main()
